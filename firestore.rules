rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: parts
    // Document ID: auto-generated
    // Fields:
    //   - id: string (required) - Unique identifier
    //   - project: string (required) - Project name
    //   - partToolDes: string (optional) - Part or tool description
    //   - partNo: string (required) - Part number
    //   - toolNo: string (optional) - Tool number
    //   - molder: string (optional) - Molder name
    //   - faLocation: string (optional) - FA location
    //   - toolingStartDate: string (optional) - Tooling start date (YYYY-MM-DD)
    //   - t1Date: string (optional) - T1 date (YYYY-MM-DD)
    //   - tfDate: string (optional) - TF date (YYYY-MM-DD)
    //   - currentStage: string (optional) - Current stage (e.g., T1, T2, TF)
    //   - tfTx: string (optional) - TF Tx status
    //   - currentStageFinishDate: string (optional) - Current stage finish date (YYYY-MM-DD)
    //   - nextStage: string (optional) - Next stage
    //   - latestStatusUpdate: string (optional) - Latest status update text
    //   - threeDIssue: string (optional) - 3D technical issue description
    //   - picture: string (optional) - URL to a picture of the part
    //   - toolDFM: string (optional) - Tool DFM status
    //   - t1: string (optional) - T1 date
    //   - t2: string (optional) - T2 date
    //   - t3: string (optional) - T3 date
    //   - t4: string (optional) - T4 date
    //   - t5: string (optional) - T5 date
    //   - t6: string (optional) - T6 date
    //   - odm: string (optional) - ODM name
    //   - pde: string (optional) - PDE name
    //   - pe: string (optional) - PE name
    //   - pte: string (optional) - PTE name
    //   - beta: string (optional) - Beta date
    //   - pilotRun: string (optional) - Pilot run date
    //   - fai: string (optional) - FAI date
    //   - xf: string (optional) - XF date
    //   - modelStatus: string (optional) - Overall status of the project model
    //   - threeDDate: string (optional) - 3D date
    //   - dfmDate: string (optional) - DFM date
    //   - uid: string (required) - Owner's user ID
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "mr.little.9x@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidProjectPart(data) {
      return data.keys().hasAll(['id', 'project', 'partNo', 'uid']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.project is string && data.project.size() > 0 && data.project.size() < 100 &&
             data.partNo is string && data.partNo.size() > 0 && data.partNo.size() < 100 &&
             data.uid is string && data.uid == request.auth.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) ||
             request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) ||
             request.resource.data.uid == resource.data.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /parts/{partId} {
      // Users can only read their own parts or if they are admin
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      
      // Users can create parts for themselves
      allow create: if isAuthenticated() && isValidProjectPart(request.resource.data) && uidUnchanged();
      
      // Users can update their own parts
      allow update: if isAuthenticated() && isDocOwner() && isValidProjectPart(request.resource.data) && uidNotModified();
      
      // Users can delete their own parts
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId) && request.resource.data.role == 'user';
      allow update: if isAuthenticated() && isAdmin(); // Only admins can change roles
    }
  }
}
